<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Frame-Options" />
        <remove name="Content-Security-Policy" />
        <add name="Content-Security-Policy" value="frame-ancestors 'self' https://hrflag.com https://*.hrflag.com http://hrflag.com http://*.hrflag.com;" />
      </customHeaders>
    </httpProtocol>
    <rewrite>
      <rules>
        <rule name="ReverseProxy to 4000" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
