NODE_ENV=development
PORT=3000

# CloudBase SQL 型数据库所在环境
TCB_ENV=workbuddy-d4grmkz5t1ad0515e

# 本地运行 CloudBase 管理 SDK 需要腾讯云 API 密钥。
# 可在腾讯云控制台「访问管理 CAM」中创建，至少需要 CloudBase/云开发相关权限。
TCB_SECRET_ID=your_tencent_cloud_secret_id
TCB_SECRET_KEY=your_tencent_cloud_secret_key

# 也兼容官方变量名：
# TENCENTCLOUD_SECRETID=your_tencent_cloud_secret_id
# TENCENTCLOUD_SECRETKEY=your_tencent_cloud_secret_key

COLLECT_CRON=0 * * * *
COLLECT_TIMEOUT_MS=15000
DASHBOARD_URL=http://localhost:3000
BRAND_NAME=HRflag
APP_NAME=AI费用监控
RECORD_RETENTION_DAYS=90

# 平台采集凭证、邮件、短信等按线上配置补充。
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
VOLC_AK=
VOLC_SK=
OPENAIHUB_BASE_URL=https://api.openai-hub.com
OPENAIHUB_TOKEN=
OPENAIHUB_USER_ID=

ALIYUN_DM_ACCESS_KEY_ID=
ALIYUN_DM_ACCESS_KEY_SECRET=
ALIYUN_DM_ACCOUNT_NAME=
ALIYUN_DM_FROM_ALIAS=HRflag
ALIYUN_DM_REGION=cn-hangzhou
ALIYUN_DM_ENDPOINT=dm.aliyuncs.com

SENDCLOUD_SMS_USER=
SENDCLOUD_SMS_KEY=
